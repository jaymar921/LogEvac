{
  "Logging": {
    "LogLevel": {
      "Default": "Error",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "ConnectionStrings": {
    "LoggingDb": "Data Source=(localdb)\\MSSQLLocalDB;Integrated Security=true;Database=Logs"
  },
  "LogEvacSettings": {
    "ApplicationName": "",
    "Environment": "",
    "CheckingFrequencyInHours": 2,
    "CleanUpDataOlderThanMinutesValue": 0, // If this has a value > 0, this will take precedence over CleanUpDataOlderThanDaysValue
    "CleanUpDataOlderThanDaysValue": 0, // If this has a value > 0, this will take precedence over CleanUpDataOlderThanWeeksValue
    "CleanUpDataOlderThanWeeksValue": 0, // If this has a value > 0, this will take precedence over CleanUpDataOlderThanMonthsValue
    "CleanUpDataOlderThanMonthsValue": 1
  }
}